rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /memories/{docId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == 'owner'
                    && request.resource.data.keys().hasAll(['url', 'caption', 'filename', 'createdAt'])
                    && request.resource.data.url is string
                    && request.resource.data.caption is string
                    && request.resource.data.caption.size() <= 500
                    && request.resource.data.filename is string;
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == 'owner';
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
